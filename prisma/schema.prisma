generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Comment {
  id          Int      @id @default(autoincrement())
  articleKey  String
  userName    String
  userEmail   String
  content     String
  ipAddress   String?
  userAgent   String?
  status     String   @default("pending")
  isDeleted   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([articleKey])
  @@index([status])
}